# Copy to .env before running `docker compose up -d`.
# Generate a production secret with: openssl rand -hex 32

# Core security
STELLEGENT_JWT_SECRET=replace-me-with-a-32-byte-or-longer-secret
STELLEGENT_JWT_EXPIRY_MIN=30
STELLEGENT_REQUIRE_SECURE_CONFIG=false

# Initial admin (provisioned only if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Public URL / cookies / transport
STELLEGENT_PUBLIC_BASE_URL=
STELLEGENT_COOKIE_SECURE=false
STELLEGENT_COOKIE_SAMESITE=lax
STELLEGENT_SECURITY_HEADERS=true
STELLEGENT_SECURITY_HSTS=false

# App
STELLEGENT_APP_NAME=Stellegent
STELLEGENT_DATA=data
STELLEGENT_DB=data/stellegent.db

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_ALLOWED_DOMAIN=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL="Stellegent <onboarding@resend.dev>"
RESEND_REPLY_TO=

# OCR
OCR_BACKEND=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_MODELS=gemini-3.5-flash,gemini-2.5-flash,gemini-3.1-flash-lite

# Local NLP (Ollama)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_AUTO_PULL=true
OLLAMA_PULL_TIMEOUT=1800
OLLAMA_REQUEST_TIMEOUT=1800
OLLAMA_NUM_CTX=4096
OLLAMA_KEEP_ALIVE=5m

# CORS (dev only; prod is same-origin)
CORS_ORIGINS=http://localhost:5173
