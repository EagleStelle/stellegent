# Copy to .env for local dev. In Docker, set these under compose `environment:`.
# All vars have defaults; only change what you need.

# Core security (change for public deploy)
STELLEGENT_JWT_SECRET=replace-me-with-a-32-byte-or-longer-secret  # openssl rand -hex 32
STELLEGENT_JWT_EXPIRY_MIN=30
STELLEGENT_REQUIRE_SECURE_CONFIG=false  # true = fail boot on weak secret; also requires RESEND_API_KEY

# Initial admin (provisioned only if no admin exists)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123

# Public URL / cookies / transport
STELLEGENT_PUBLIC_BASE_URL=          # public origin, no trailing slash; pins email/OAuth links
STELLEGENT_COOKIE_SECURE=false       # true behind HTTPS/Cloudflare
STELLEGENT_COOKIE_SAMESITE=lax       # lax | strict | none
STELLEGENT_SECURITY_HEADERS=true
STELLEGENT_SECURITY_HSTS=false       # true for HTTPS-only

# App
STELLEGENT_APP_NAME=Stellegent
STELLEGENT_DATA=data                 # relative = repo root (/app in container)
STELLEGENT_DB=data/stellegent.db

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=           # e.g. https://your.domain/api/v1/auth/google/callback
GOOGLE_ALLOWED_DOMAIN=               # restrict to one domain; blank = any

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Stellegent <onboarding@resend.dev>
RESEND_REPLY_TO=

# OCR
OCR_BACKEND=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Local NLP (Ollama)
OLLAMA_HOST=http://127.0.0.1:11434   # in Docker: http://ollama:11434
OLLAMA_MODEL=phi3:mini
OLLAMA_AUTO_PULL=true
OLLAMA_PULL_TIMEOUT=1800
OLLAMA_REQUEST_TIMEOUT=600   # per-summary generate timeout; raise for slow CPU-only hosts

# CORS (dev only; prod is same-origin)
CORS_ORIGINS=http://localhost:5173
