# Copy to .env and edit. .env is git-ignored.

# JWT signing key. Must be >= 32 bytes.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
STELLEGENT_JWT_SECRET=replace-me-with-a-32-byte-or-longer-secret

STELLEGENT_DATA=./data
STELLEGENT_DB=./stellegent.db

OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=phi3:mini
