# Copy to .env and edit. .env is git-ignored. Loaded from the repo root.

# JWT signing key. Must be >= 32 bytes.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
STELLEGENT_JWT_SECRET=replace-me-with-a-32-byte-or-longer-secret

# Runtime state (db + capture artefacts). Relative paths resolve to repo root.
STELLEGENT_DATA=./data
STELLEGENT_DB=./data/stellegent.db

# ---- OCR ----
# auto = Gemini when GEMINI_API_KEY is set, else PP-OCR (RapidOCR) fallback.
# Force with: gemini | paddle
OCR_BACKEND=auto
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---- Local NLP (PP-OCR fallback path: correction + summary via Ollama) ----
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=phi3:mini

# ---- Frontend dev ----
# Vite dev server origin allowed by CORS (prod serves the SPA same-origin).
CORS_ORIGINS=http://localhost:5173
